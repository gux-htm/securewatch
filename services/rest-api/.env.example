# ── MySQL (XAMPP) ───────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=securewatch

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=24h

# ── HMAC Audit Signing ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_HMAC_KEY=replace-with-32-byte-hex-secret

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=127.0.0.1:9092

# ── File Watcher ──────────────────────────────────────────────────────────────
WATCH_DIRECTORY=./watched
WATCHER_PORT=3006
REST_API_URL=http://localhost:3001

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# NOTE: DB_PASSWORD is empty by default — XAMPP MySQL root has no password.
# If you set a password in phpMyAdmin, update DB_PASSWORD above.
